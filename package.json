{
  "name": "@calldesk/annoy-node",
  "version": "4.0.1",
  "description": "Node bindings for Annoy, an efficient Approximate Nearest Neighbors implementation written in C++.",
  "main": "index.js",
  "gypfile": true,
  "scripts": {
    "install": "node-gyp-build",
    "build": "node-gyp rebuild",
    "build:prebuilt": "npx prebuildify --target 22.0.0 --strip",
    "docker:build": "docker build --platform linux/amd64 -t annoy-node-builder . && docker run --name temp-annoy-builder annoy-node-builder && docker cp temp-annoy-builder:/build/prebuilds/. ./prebuilds/ && docker rm temp-annoy-builder",
    "docker:clean": "docker rm -f temp-annoy-builder 2>/dev/null || true",
    "test": "make test"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:jimkang/annoy-node.git"
  },
  "keywords": [
    "annoy",
    "approximate",
    "nearest",
    "neighbor",
    "search",
    "vector",
    "machine learning"
  ],
  "author": "Jim Kang",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jimkang/annoy-node/issues"
  },
  "homepage": "https://github.com/jimkang/annoy-node",
  "publishConfig": {
    "registry": "https://calldesk-974442180126.d.codeartifact.eu-west-1.amazonaws.com/npm/calldesk-repository/"
  },
  "dependencies": {
    "bindings": "^1.2.1",
    "level": "^6.0.0",
    "nan": "^2.27.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "assert-no-error": "^1.0.0",
    "d3-queue": "^3.0.3",
    "level-sublevel": "^6.6.4",
    "ndjson": "^1.5.0",
    "node-worker-threads-pool": "^1.5.1",
    "prebuildify": "^6.0.1",
    "tape": "^5.6.6",
    "through2": "^2.0.1"
  }
}
